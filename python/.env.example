# LLM 配置（默认使用 mock 模式，无需真实 API 即可运行）
LLM_PROVIDER=mock
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.minimax.chat/v1
LLM_MODEL=MiniMax-M2.7
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# 结构化输出修复重试次数（解析失败后带错误重新生成）
LLM_STRUCTURED_MAX_REPAIR=2

# 超预算调整策略: rule=规则渐进降级(默认) / agent=ReplanAgent工具调用循环(需真实LLM)
REPLAN_MODE=rule
REPLAN_MAX_STEPS=6

# 公网 demo 防刷: 设置后, Streamlit 界面需输入此访问码才能使用真实 LLM 模式
# (留空 = 不限制, 适合本地开发)
DEMO_ACCESS_CODE=

# 可观测性: 本地 JSONL 链路追踪（默认开启, 写入 python/traces/）
TRACE_ENABLED=true
# TRACE_DIR=traces

# 可观测性: Langfuse（可选, 填上密钥即自动上报, 需 pip install 'langfuse>=2.39,<3'）
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# RAG: 目的地知识库检索（默认开启, 无 Key 时用本地 BM25, 配置后用向量检索）
RAG_ENABLED=true
RAG_TOP_K=4
EMBEDDING_MODEL=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

# 预算循环最大重试次数
BUDGET_MAX_RETRIES=3

# 并行 Agent 超时（秒）
PARALLEL_TIMEOUT=30

# API 服务
API_HOST=0.0.0.0
API_PORT=8000

LOG_LEVEL=INFO
